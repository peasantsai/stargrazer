{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "assignees": ["danyworks"],
  "schedule": ["before 8am on Monday"],
  "timezone": "UTC",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Go modules",
      "matchManagers": ["gomod"],
      "groupName": "go dependencies",
      "groupSlug": "go-deps",
      "automerge": false
    },
    {
      "description": "Go patch/minor — auto-merge",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "npm production deps",
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "groupName": "npm production dependencies",
      "groupSlug": "npm-prod"
    },
    {
      "description": "npm dev deps",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "npm dev dependencies",
      "groupSlug": "npm-dev",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "GitHub Actions — pin digests, auto-merge minor/patch",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "gha",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Major version bumps — require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    }
  ]
}
